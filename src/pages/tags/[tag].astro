---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import Base from "../../layouts/Base.astro";
import { postsForTagSlug, tagCounts, tagSlug } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  // One route per distinct tag; carry the original label for display.
  return tagCounts(posts).map(({ tag }) => ({
    params: { tag: tagSlug(tag) },
    props: { label: tag, posts: postsForTagSlug(posts, tagSlug(tag)) },
  }));
}

const { label, posts } = Astro.props;
---

<Base title={`#${label} · til`} description={`TIL notes tagged ${label}.`}>
  <h1 class="lead">
    Tagged <span class="accent">#{label}</span>
  </h1>
  <p class="lead-sub">
    {posts.length} note{posts.length === 1 ? "" : "s"}.
  </p>

  <ul class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </ul>

  <a class="back" href="/">← all notes</a>
</Base>
