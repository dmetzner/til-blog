---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import LikeButton from "../../components/LikeButton.astro";
import { byDateDesc, fmtDate, readingMinutes, tagSlug } from "../../lib/posts";

export async function getStaticPaths() {
  // Build a page for EVERY post, drafts included — drafts are reachable only via
  // ?preview (gated below) and kept out of indexes/feeds/sitemap. Prev/next nav
  // is computed from published posts only, so a draft never appears in it and a
  // published post never links to one. Newer = previous in the date-sorted list.
  const all = (await getCollection("posts")).sort(byDateDesc);
  const published = all.filter((p) => !p.data.draft);
  return all.map((post) => {
    const i = published.findIndex((p) => p.id === post.id);
    return {
      params: { slug: post.id },
      props: {
        post,
        newer: i === -1 ? null : (published[i - 1] ?? null),
        older: i === -1 ? null : (published[i + 1] ?? null),
      },
    };
  });
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const minutes = readingMinutes(post.body ?? "");
const iso = post.data.pubDate.toISOString();
const isDraft = post.data.draft;
---

<Base
  title={`${post.data.title} · til`}
  description={post.data.description}
  article={{ published: post.data.pubDate, tags: post.data.tags }}
  noindex={isDraft}
>
  {
    isDraft && (
      <div class="draft-gate" data-draft-gate>
        <h1 class="article-title">Not found</h1>
        <p>
          This note isn’t published yet. <a href="/">← all notes</a>
        </p>
      </div>
    )
  }
  <article class:list={[{ "is-draft-hidden": isDraft }]}>
    {isDraft && <p class="draft-banner mono">● draft preview — not published</p>}
    <header class="article-head">
      <p class="post-meta">
        <time class="post-date" datetime={iso}>{fmtDate(post.data.pubDate)}</time>
        <span class="dot" aria-hidden="true">·</span>
        <span class="read-time">~{minutes} min read</span>
      </p>
      <h1 class="article-title">{post.data.title}</h1>
    </header>
    <div class="prose">
      <Content />
    </div>
    <div class="post-actions">
      {
        post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((t) => (
              <a class="tag tag-link" href={`/tags/${tagSlug(t)}/`}>
                {t}
              </a>
            ))}
          </div>
        )
      }
      <div class="post-buttons">
        <LikeButton slug={post.id} />
        <button type="button" class="share-btn mono" data-share aria-label="Share this note">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7" />
            <path d="M12 15V3M8 7l4-4 4 4" />
          </svg>
          <span data-share-label>Share</span>
        </button>
      </div>
    </div>

    {
      (newer || older) && (
        <nav class="post-nav" aria-label="More notes">
          {older ? (
            <a class="post-nav-link prev" href={`/posts/${older.id}/`}>
              <span class="post-nav-dir">← older</span>
              <span class="post-nav-title">{older.data.title}</span>
            </a>
          ) : (
            <span />
          )}
          {newer ? (
            <a class="post-nav-link next" href={`/posts/${newer.id}/`}>
              <span class="post-nav-dir">newer →</span>
              <span class="post-nav-title">{newer.data.title}</span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }

    <a class="back" href="/">← all notes</a>
  </article>
</Base>
