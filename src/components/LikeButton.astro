---
import { config } from "../config";

interface Props {
  slug: string;
}
const { slug } = Astro.props;

// Feature is off (and renders nothing) until a Supabase project is configured.
const { supabaseUrl, supabaseKey } = config.likes;
const enabled = Boolean(supabaseUrl && supabaseKey);
---

{
  enabled && (
    <button
      type="button"
      class="like-btn mono"
      data-like
      data-slug={slug}
      data-url={supabaseUrl}
      data-key={supabaseKey}
      aria-pressed="false"
      aria-label="Like this note"
    >
      <svg class="like-heart" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 21s-7.5-4.9-10-9.3C.5 8.6 2 5 5.3 5c2 0 3.4 1.3 4.2 2.6h0C10.3 6.3 11.7 5 13.7 5 17 5 18.5 8.6 17 11.7 14.5 16.1 12 21 12 21z" />
      </svg>
      <span class="like-count" data-like-count aria-hidden="true" />
    </button>
  )
}

<script>
  // Per-post like button. Privacy-by-design:
  //  • the count is fetched only when the button scrolls into view, so a bounce
  //    or a link-preview never opens a connection to Supabase;
  //  • a like is a deliberate click (opt-in), deduped client-side in localStorage
  //    (no cookie); the server only ever stores one aggregate integer per slug.
  // Talks to Supabase over plain PostgREST so this static site pulls in no SDK.
  const btn = document.querySelector<HTMLButtonElement>("[data-like]");
  if (btn) {
    const { slug = "", url = "", key = "" } = btn.dataset;
    const countEl = btn.querySelector<HTMLElement>("[data-like-count]");
    const storeKey = `til-liked:${slug}`;
    const headers = { apikey: key, Authorization: `Bearer ${key}` };

    let liked = localStorage.getItem(storeKey) === "1";
    let count = 0;
    let loaded = false;
    let busy = false;

    const render = () => {
      btn.classList.toggle("liked", liked);
      btn.setAttribute("aria-pressed", String(liked));
      if (countEl) countEl.textContent = loaded ? String(count) : "";
    };
    const persist = () => {
      if (liked) localStorage.setItem(storeKey, "1");
      else localStorage.removeItem(storeKey);
    };
    render();

    const fetchCount = async () => {
      try {
        const res = await fetch(
          `${url}/rest/v1/til_likes?slug=eq.${encodeURIComponent(slug)}&select=likes`,
          { headers },
        );
        const rows = (await res.json()) as Array<{ likes: number }>;
        count = rows[0]?.likes ?? 0;
        loaded = true;
        render();
      } catch {
        /* offline / blocked → leave the count blank, button still likeable */
      }
    };

    // Lazy: only reach out to Supabase once the button is actually on screen.
    const io = new IntersectionObserver((entries) => {
      if (entries.some((e) => e.isIntersecting)) {
        io.disconnect();
        fetchCount();
      }
    });
    io.observe(btn);

    btn.addEventListener("click", async () => {
      if (busy) return;
      busy = true;
      const dir = liked ? -1 : 1;
      // optimistic flip
      liked = !liked;
      if (loaded) count = Math.max(0, count + dir);
      persist();
      render();
      try {
        const res = await fetch(`${url}/rest/v1/rpc/bump_like`, {
          method: "POST",
          headers: { ...headers, "Content-Type": "application/json" },
          body: JSON.stringify({ post_slug: slug, dir }),
        });
        const fresh = (await res.json()) as number;
        if (typeof fresh === "number") {
          count = fresh;
          loaded = true;
          render();
        }
      } catch {
        // revert the optimistic change on failure
        liked = !liked;
        if (loaded) count = Math.max(0, count - dir);
        persist();
        render();
      } finally {
        busy = false;
      }
    });
  }
</script>
