---
// Theme cycle button: system → light → dark. The active icon is swapped by
// scripts/site.ts (and on first paint by the inline bootstrap in Base.astro).
// All three icons are rendered; CSS/JS shows only the one matching the pref.
---

<button type="button" class="theme-btn" data-theme-toggle aria-label="change theme" title="theme">
  <svg
    class="theme-icon"
    data-icon="system"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="2" y="4" width="20" height="13" rx="2"></rect>
    <path d="M8 21h8M12 17v4"></path>
  </svg>
  <svg
    class="theme-icon"
    data-icon="light"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
    ></path>
  </svg>
  <svg
    class="theme-icon"
    data-icon="dark"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>
