---
// A little duckling that waddles across the footer line. Ported from the
// portfolio's App.tsx WalkingDuck — legs step, body rocks, comic style.
---

<svg class="wduck" viewBox="0 0 64 62" aria-hidden="true">
  <defs>
    <linearGradient id="wd" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffe15c"></stop>
      <stop offset="1" stop-color="#f6b400"></stop>
    </linearGradient>
  </defs>
  <g class="wd-leg wd-leg1">
    <rect x="21" y="43" width="3.6" height="12" rx="1.8" fill="#ef8b1f"></rect>
    <path d="M16 55 H27 L24.5 59 H18.5 Z" fill="#ef8b1f"></path>
  </g>
  <g class="wd-leg wd-leg2">
    <rect x="32" y="43" width="3.6" height="12" rx="1.8" fill="#ef8b1f"></rect>
    <path d="M27 55 H38 L35.5 59 H29.5 Z" fill="#ef8b1f"></path>
  </g>
  <g class="wd-body">
    <path d="M11 30 L2 25 L5 38 Z" fill="url(#wd)"></path>
    <ellipse cx="26" cy="33" rx="18" ry="13" fill="url(#wd)"></ellipse>
    <circle cx="45" cy="19" r="11" fill="url(#wd)"></circle>
    <path d="M54 15 H64 L60 22 H54 Z" fill="#ef8b1f"></path>
    <circle cx="47" cy="16" r="2" fill="#0a0a0f"></circle>
    <path
      d="M18 32 q8 7 17 1"
      fill="none"
      stroke="#b97f0a"
      stroke-opacity="0.4"
      stroke-width="2.5"
      stroke-linecap="round"></path>
  </g>
</svg>
